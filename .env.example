# Copy to `.env` in the same directory as this repo (`cp .env.example .env`).
# Mossy loads `.env` automatically via `mossy.env.load_mossy_env()` (see `main.py` / `mossy/main.py`).

# -----------------------------------------------------------------------------
# Mossy settings (read with os.getenv in code)
# -----------------------------------------------------------------------------

# Interactive CLI chat model (defaults to PLATFORMER_SKILL_MODEL if unset).
PLATFORMER_CLI_MODEL=

# Skill worker (chat LLM; constructed lazily on first executed task).
PLATFORMER_SKILL_MODEL=openai:gpt-5.4-mini

# Non-empty: disables think_next (follow-ups and idle housekeeping).
PLATFORMER_DISABLE_AUTONOMOUS=

# Optional: goal string for a single IDLE housekeeping task after non-idle work (never chains IDLE→IDLE).
PLATFORMER_IDLE_GOAL=

# HTTP bind (FastAPI / uvicorn).
PLATFORMER_HOST=127.0.0.1
PORT=8765
# Optional bearer key for protected HTTP endpoints (/run, /queue, /agui, /archive/files).
MOSSY_API_KEY=

# AG-UI web chat channel (SSE). Enabled with HTTP unless you pass --no-agui.
# POST endpoint path (default /agui). Set AGUI_CORS_ORIGINS for browser clients.
PLATFORMER_AGUI_MODEL=
AGUI_PATH=/agui
AGUI_CORS_ORIGINS=

# Browser /ui chat endpoint (POST /chat).
PLATFORMER_CHAT_MODEL=
CHAT_HISTORY_TTL_SECONDS=7200
CHAT_HISTORY_MAX_THREADS=500
CHAT_HISTORY_MAX_MESSAGES=40

# Slack Socket Mode channel.
# SLACK_BOT_TOKEN is the bot OAuth token from "OAuth & Permissions" (xoxb-...).
# SLACK_APP_TOKEN is the app-level token with connections:write from "Socket Mode" (xapp-...).
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Optional Slack model/history controls.
PLATFORMER_SLACK_MODEL=
SLACK_HISTORY_TTL_SECONDS=7200
SLACK_HISTORY_MAX_CONVERSATIONS=500
SLACK_HISTORY_MAX_MESSAGES=40

# Non-empty: log every incoming Slack event type to the terminal (verbose).
SLACK_DEBUG=

# -----------------------------------------------------------------------------
# Integrations (capabilities). Each is gated on its skill and is simply absent
# when unconfigured, so Mossy still boots without these set.
# -----------------------------------------------------------------------------

# Freshdesk (capability: freshdesk).
# FRESHDESK_API_KEY is the Basic-auth value sent verbatim as `Authorization: Basic <value>`
# (base64 of "<api_key>:X"), matching existing Mossy/Freshdesk deployments.
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=

# GitHub (capability: github). PAT with repo + pull-request scopes.
GITHUB_PERSONAL_ACCESS_TOKEN=
# Optional: override the hosted GitHub MCP endpoint.
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
# Optional: base directory for local clones (default: ./repos under the working dir).
GITHUB_WORKDIR=

# Archives (capability: archives). Root for zip/unzip and protected file downloads.
# Defaults to the repo root when unset.
MOSSY_ARCHIVE_ROOT=
# Max total storage under MOSSY_ARCHIVE_ROOT before saving a new zip.
# Accepts bytes or suffixes like 100MB / 1GB. Default: 100MB.
ARCHIVE_MAX_STORAGE=

# -----------------------------------------------------------------------------
# Provider API keys — OpenAI is required for the defaults above.
# -----------------------------------------------------------------------------

OPENAI_API_KEY=
