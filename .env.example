# Copy to `.env` in the same directory as this repo (`cp .env.example .env`).
# Mossy loads `.env` automatically via `mossy.env.load_mossy_env()` (see `main.py` / `mossy/main.py`).

# -----------------------------------------------------------------------------
# Mossy settings (read with os.getenv in code)
# -----------------------------------------------------------------------------

# Interactive CLI chat model (defaults to PLATFORMER_SKILL_MODEL if unset).
PLATFORMER_CLI_MODEL=

# Skill worker (chat LLM; constructed lazily on first executed task).
PLATFORMER_SKILL_MODEL=openai:gpt-5.4-mini

# Non-empty: disables think_next (follow-ups and idle housekeeping).
PLATFORMER_DISABLE_AUTONOMOUS=

# Optional: goal string for a single IDLE housekeeping task after non-idle work (never chains IDLE→IDLE).
PLATFORMER_IDLE_GOAL=

# HTTP bind (FastAPI / uvicorn).
PLATFORMER_HOST=127.0.0.1
PORT=8765

# -----------------------------------------------------------------------------
# Provider API keys — OpenAI is required for the defaults above.
# -----------------------------------------------------------------------------

OPENAI_API_KEY=
